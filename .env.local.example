# Copy to .env.local and fill in. Never commit .env.local.
# Network is Base Sepolia (eip155:84532) throughout — testnet only.

# ── x402 payments (paid unlock) ──────────────────────────────────────────────
# The paid article API settles USDC via the Coinbase CDP x402 facilitator.
# Create a CDP API key at https://portal.cdp.coinbase.com → API Keys.
X402_NETWORK=eip155:84532
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ── Solana devnet x402 lane (parallel paid-unlock endpoint) ──────────────────
# /api/v1/sol/articles/<slug> settles USDC-SPL on solana-devnet via the PayAI
# facilitator. SOL_PAYTO is the devnet recipient (base58 pubkey); price reuses
# the per-slug priceUSDC from data/attestation-index.json. Devnet USDC-SPL mint
# is a constant (4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU).
SOL_PAYTO=
SOLANA_DEVNET_RPC=https://api.devnet.solana.com
# Throwaway funded keypair (base58 secret) used ONLY by the e2e verification
# script to pay the endpoint — never the running app.
SOL_TEST_PAYER_SECRET=

# ── Content encryption (article bodies) ──────────────────────────────────────
# Article bodies are stored AES-256-GCM-encrypted (content/reports/<slug>.enc)
# and decrypted server-side on paid unlock. 32-byte key.
# Generate: openssl rand -base64 32
CONTENT_ENC_KEY=

# ── EAS (publish + seed scripts) ─────────────────────────────────────────────
# On-chain attestation of authorship/price. Contracts are the Base Sepolia
# canonical addresses; SCHEMA_UID comes from scripts/eas-register-schema.ts.
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021
EAS_SCHEMA_REGISTRY=0x4200000000000000000000000000000000000020
EAS_SCHEMA_UID=
NEXT_PUBLIC_EAS_SCHEMA_UID=
EAS_GRAPHQL_URL=https://base-sepolia.easscan.org/graphql
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Demo / seed scripts only (NEVER a mainnet key) ───────────────────────────
# Used by scripts/{eas-register-schema,seed-attest}.ts to sign on Base Sepolia.
# Not read by the running app.
DEMO_AUTHOR_PRIVATE_KEY=
